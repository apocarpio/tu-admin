# TU Admin - GitIgnore

# ═══════════════════════════════════════════════════════════
# FICHIERS SENSIBLES (NE JAMAIS COMMITTER)
# ═══════════════════════════════════════════════════════════
data/.db_credentials
data/.tu_app_path
*.enc

# ═══════════════════════════════════════════════════════════
# FICHIERS TEMPORAIRES
# ═══════════════════════════════════════════════════════════
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# ═══════════════════════════════════════════════════════════
# BACKUPS
# ═══════════════════════════════════════════════════════════
*.backup
*.backup.*
*.bak
*.BAK
*.old

# ═══════════════════════════════════════════════════════════
# LOGS
# ═══════════════════════════════════════════════════════════
*.log
logs/*.log
!logs/.gitkeep

# ═══════════════════════════════════════════════════════════
# BACKUPS SQL
# ═══════════════════════════════════════════════════════════
*.sql
backups/*.sql

# ═══════════════════════════════════════════════════════════
# DATA ET CACHE
# ═══════════════════════════════════════════════════════════
data/*
!data/.gitkeep

# ═══════════════════════════════════════════════════════════
# DIRECTORIES À PRÉSERVER VIDES
# ═══════════════════════════════════════════════════════════
!*/.gitkeep
